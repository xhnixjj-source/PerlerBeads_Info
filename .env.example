NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Required in production (Vercel etc.): pre-orders /api/orders/prep, admin APIs, npm run seed. Never expose to the client.
# Supabase: Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: npm run seed:demo-bulk (default 20 patterns + 20 suppliers). Override count: DEMO_BULK_COUNT=30

# NextAuth (admin login at /admin/login). Required in production. In local dev, if omitted, a built-in dev secret is used — still recommended to set this.
# If you change this value, old session cookies become invalid → open /api/auth/reset-session or clear site cookies, then sign in again.
NEXTAUTH_SECRET=generate_a_long_random_string
# Production: https://perlerbeadschan.com (or your primary domain)
NEXTAUTH_URL=http://localhost:3000

# Storefront OAuth (optional). Callback URLs in Google/Facebook consoles: http://localhost:3000/api/auth/callback/google (and /callback/facebook).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Optional: openid-client HTTP timeout ms for OAuth discovery (default 20000). Increase if you see SIGNIN_OAUTH_ERROR timeout.
# OAUTH_HTTP_TIMEOUT_MS=30000
# Optional: share session cookie across subdomains (e.g. admin.perlerbeadschan.com)
# AUTH_COOKIE_DOMAIN=.perlerbeadschan.com
# Optional: explicit admin hostnames for middleware rewrites (comma-separated). Default: any host starting with "admin."
# ADMIN_HOST=admin.perlerbeadschan.com

# Legacy (deprecated): single shared password cookie — replaced by NextAuth + admin_users
# ADMIN_DASHBOARD_PASSWORD=
# ADMIN_DASHBOARD_EMAIL=

# Inquiry email notifications (Resend)
RESEND_API_KEY=re_xxx
INQUIRY_NOTIFY_EMAIL=ops@example.com
INQUIRY_FROM_EMAIL=PerlerHub <onboarding@resend.dev>

# AI analyze route (Gemini API key, optional — public /api/analyze-pattern)
GOOGLE_API_KEY=

# Vertex AI (admin: /api/admin/ai/*). Use a service account JSON via GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
# Optional: Gemini model id on Vertex (default gemini-1.5-flash)
VERTEX_AI_MODEL=gemini-1.5-flash
